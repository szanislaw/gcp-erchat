# AWS Credentials - Required for Athena access
# Option 1: Set these environment variables
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-east-1

# Option 2: Use AWS CLI configuration (recommended)
# Run: aws configure
# This will store credentials in ~/.aws/credentials

# Note: If both are set, environment variables take precedence

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Streamlit Configuration
STREAMLIT_PORT=8501
