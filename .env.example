# Redshift Connection (password auth)
REDSHIFT_HOST=your-workgroup.123456789.ap-east-1.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DBNAME=dev
REDSHIFT_USER=your_db_username
REDSHIFT_PASSWORD=your_db_password

# Schema name — set to the nxg_XXXXXXXX_XXXX schema for your tenant
REDSHIFT_SCHEMA=nxg_107747471_q2sj

# Model Configuration
# USE_QUANTIZATION=true  → 4-bit quantization (~4-5GB VRAM, slower, needed on <16GB GPUs)
# USE_QUANTIZATION=false → float16 (~13GB VRAM, faster, recommended for L4 24GB)
USE_QUANTIZATION=false

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Streamlit Configuration
STREAMLIT_PORT=8501
