[Unit]
Description=NLQ to Athena SQL API
After=network.target

[Service]
Type=simple
User=shawnyzy
WorkingDirectory=/home/shawnyzy/sqlcoder-src
Environment="PATH=/home/shawnyzy/miniconda3/envs/venv1/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/shawnyzy/miniconda3/envs/venv1/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=10
StandardOutput=append:/home/shawnyzy/sqlcoder-src/logs/uvicorn.log
StandardError=append:/home/shawnyzy/sqlcoder-src/logs/uvicorn_error.log

[Install]
WantedBy=multi-user.target
